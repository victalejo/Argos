{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/log-commit-to-changelog.sh",
            "timeout": 30,
            "statusMessage": "Actualizando CHANGELOG.md…"
          }
        ]
      }
    ]
  }
}
